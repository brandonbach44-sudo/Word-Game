"""Combine-Wordlists

Usage examples:
    python scripts/Combine-Wordlists --base data/words.ts --extra data/anagram_dictionary.txt --min 3 --max 10 --out data/words.ts --format ts

This script:
 - Reads a base words file (TS array or any file with quoted words)
 - Reads an extra word list (one word per line)
 - Filters by length and alphabetic characters
 - Deduplicates and optionally sorts
 - Writes output as TypeScript array, JSON array, or plain text
"""

from __future__ import annotations
import argparse
import json
import os
import re
from typing import List, Set


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Combine two wordlists into one with filtering and dedupe options")
    p.add_argument("--base", default="data/words.ts", help="Path to base words file (TS array or any file with quoted words)")
    p.add_argument("--extra", default="", help="Path to extra wordlist (one word per line). Leave empty to skip extras")
    p.add_argument("--min", type=int, default=3, help="Minimum word length to include")
    p.add_argument("--max", type=int, default=10, help="Maximum word length to include")
    p.add_argument("--out", default="data/words.ts", help="Output path")
    p.add_argument("--format", choices=("ts", "json", "txt"), default="ts", help="Output format: ts (TypeScript array), json, or txt (one per line)")
    p.add_argument("--sort", choices=("none", "alpha"), default="alpha", help="Sort extra words before appending (default: alpha)")
    p.add_argument("--preserve-base-order", action="store_true", help="Keep base word order first, then extras")
    p.add_argument("--force", action="store_true", help="Overwrite existing output file")
    return p.parse_args()


def read_base_words(path: str) -> List[str]:
    text = open(path, "r", encoding="utf-8").read()
    # Find single- or double-quoted words
    words = re.findall(r"'([^']+)'", text) + re.findall(r'"([^\"]+)"', text)
    # Normalize to lower-case and preserve order
    return [w.strip().lower() for w in words if w and w.strip()]


def read_extra_words(path: str, min_len: int, max_len: int) -> List[str]:
    out: List[str] = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            w = line.strip().lower()
            if not w:
                continue
            if not w.isalpha():
                continue
            if len(w) < min_len or len(w) > max_len:
                continue
            out.append(w)
    return out


def write_output(words: List[str], out_path: str, fmt: str) -> None:
    os.makedirs(os.path.dirname(out_path) or ".", exist_ok=True)
    if fmt == "ts":
        with open(out_path, "w", encoding="utf-8") as f:
            f.write("[\n")
            for i, w in enumerate(words):
                sep = "," if i < len(words) - 1 else ""
                f.write(f"'{w}'{sep}\n")
            f.write("]\n")
    elif fmt == "json":
        with open(out_path, "w", encoding="utf-8") as f:
            json.dump(words, f, indent=2, ensure_ascii=False)
    elif fmt == "txt":
        with open(out_path, "w", encoding="utf-8") as f:
            for w in words:
                f.write(w + "\n")


def main() -> None:
    args = parse_args()

    if os.path.exists(args.out) and not args.force:
        print(f"Output exists: {args.out}. Use --force to overwrite.")
        return

    base = []
    if os.path.exists(args.base):
        base = read_base_words(args.base)
    else:
        print(f"Base file not found: {args.base}. Continuing with empty base list.")

    base_set: Set[str] = set(base)

    extras = []
    if args.extra:
        if os.path.exists(args.extra):
            extras = read_extra_words(args.extra, args.min, args.max)
        else:
            print(f"Extra file not found: {args.extra}. No extras will be added.")

    # Filter out extras already in base
    new_extras = [w for w in extras if w not in base_set]

    if args.sort == "alpha":
        new_extras = sorted(new_extras)

    if args.preserve_base_order:
        combined = base + new_extras
    else:
        # produce deterministic order: base unique words first (sorted), then extras
        combined = sorted(set(base)) + new_extras

    write_output(combined, args.out, args.format)

    print(f"Base words: {len(base)}")
    print(f"New words added: {len(new_extras)}")
    print(f"Total words: {len(combined)}")


if __name__ == '__main__':
    main()
